# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=faces

# ── Database (if using direct Postgres instead of Supabase client) ────────────
DATABASE_URL=sqlite:///./biometric.db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=60

# ── 2FA / OTP ─────────────────────────────────────────────────────────────────
SKIP_2FA=false
ADMIN_EMAIL=admin@biosecuregate.com

# ── SMTP (for email OTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── ML / Face recognition ────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.45
FACE_MODEL_PATH=app/models/arcface.onnx

# ── Fingerprint ───────────────────────────────────────────────────────────────
FINGERPRINT_THRESHOLD=0.85
FINGERPRINT_FP_SCORE_THRESHOLD=0.85
FINGERPRINT_FP_HIGH=0.90
FINGERPRINT_FP_LOW=0.65
FINGERPRINT_REVIEW_SIMILARITY=0.40

# ── Model service (URL where model_service FastAPI runs) ──────────────────────
# Local dev:   http://localhost:8001
# Cloud Run:   https://YOUR-MODEL-SERVICE-URL.run.app
MODEL_SERVICE_URL=http://localhost:8001
MODEL_SERVICE_TIMEOUT=30
