# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=faces

# ── Database (if using direct Postgres instead of Supabase client) ────────────
DATABASE_URL=sqlite:///./biometric.db

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_MINUTES=60

# ── 2FA / OTP ─────────────────────────────────────────────────────────────────
SKIP_2FA=false
ADMIN_EMAIL=admin@biosecuregate.com

# ── SMTP (for email OTP) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── ML / Face recognition ────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.45
FACE_MODEL_PATH=app/models/arcface.onnx

# ── Fingerprint ───────────────────────────────────────────────────────────────
FINGERPRINT_THRESHOLD=0.85
FINGERPRINT_FP_SCORE_THRESHOLD=0.85
FINGERPRINT_FP_HIGH=0.90
FINGERPRINT_FP_LOW=0.65
FINGERPRINT_REVIEW_SIMILARITY=0.40
FINGERPRINT_V2_THRESHOLD=0.18
FINGERPRINT_V2_QUALITY_THRESHOLD=0.30
FINGERPRINT_V2_FP_SCORE_THRESHOLD=0.20
FINGERPRINT_V2_LIKENESS_THRESHOLD=0.58
FINGERPRINT_V2_MIN_COVERAGE=0.14
FINGERPRINT_V2_MIN_ORIENTATION_ENTROPY=0.58
FINGERPRINT_V2_MIN_KP_COUNT=35
FINGERPRINT_V2_MIN_KP_SPREAD=0.12
FINGERPRINT_V2_MIN_TILE_ACTIVE_RATIO=0.28
FINGERPRINT_V2_MAX_TILE_COVERAGE_STD=0.24
FINGERPRINT_V2_MIN_EDGE_COMPONENT_COUNT=45
FINGERPRINT_V2_MAX_LARGEST_EDGE_COMPONENT_RATIO=0.32
FINGERPRINT_V2_MIN_PERIODIC_TILE_RATIO=0.20
FINGERPRINT_V2_MIN_MEAN_PERIODICITY=4.50
FINGERPRINT_V2_MIN_RIDGE_BLOCK_RATIO=0.12

# ── Model service (URL where model_service FastAPI runs) ──────────────────────
# Local dev:   http://localhost:8001
# Cloud Run:   https://YOUR-MODEL-SERVICE-URL.run.app
MODEL_SERVICE_URL=http://localhost:8001
MODEL_SERVICE_TIMEOUT=30
